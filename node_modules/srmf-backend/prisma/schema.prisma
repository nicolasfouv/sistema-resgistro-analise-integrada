// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// AUTH AND USERS
model applicant {
  id       String   @id @default(uuid())
  name     String   @map("nome")
  email    String   @unique
  password String   @map("senha")
  date     DateTime @default(now()) @map("data")
  message  String?  @map("mensagem")

  @@map("solicitante")
}

model user {
  id       String  @id @default(uuid())
  name     String  @map("nome")
  email    String  @unique
  password String  @map("senha")
  roleId   String  @default("2") @map("id_funcao")
  role     role    @relation(fields: [roleId], references: [id])
  userPic  String?

  userAccess userAccess[]
  auditLogs  auditLog[]

  @@map("usuario")
}

model role {
  id   String @id @default(uuid())
  name String @map("nome")

  user user[]

  @@map("funcao")
}

model group {
  id   String @id @default(uuid())
  name String @unique @map("nome")

  groupAccess groupAccess[]

  @@map("grupo")
}

model category {
  id           String  @id @default(uuid())
  name         String  @unique @map("nome")
  categoryIcon String? @map("icone_categoria")

  subCategory subCategory[]

  @@map("categoria")
}

model subCategory {
  id         String   @id @default(uuid())
  name       String   @unique @map("nome")
  categoryId String   @map("id_categoria")
  category   category @relation(fields: [categoryId], references: [id])

  form form[]

  @@map("sub_categoria")
}

model form {
  id            String      @id @default(uuid())
  name          String      @map("nome")
  subCategoryId String      @map("id_sub_categoria")
  subCategory   subCategory @relation(fields: [subCategoryId], references: [id])

  group      groupAccess[]
  userAccess userAccess[]
  auditLog   auditLog[]

  @@map("formulario")
}

model userAccess {
  id              String           @id @default(uuid())
  userId          String           @map("id_usuario")
  user            user             @relation(fields: [userId], references: [id])
  formId          String           @map("id_formulario")
  form            form             @relation(fields: [formId], references: [id])
  accessLevelId   String?          @map("id_nivel_acesso")
  enumAccessLevel enumAccessLevel? @relation(fields: [accessLevelId], references: [id])

  @@map("autorizacao_usuario")
}

model groupAccess {
  id              String           @id @default(uuid())
  groupId         String           @map("id_grupo")
  group           group            @relation(fields: [groupId], references: [id])
  formId          String           @map("id_formulario")
  form            form             @relation(fields: [formId], references: [id])
  accessLevelId   String?          @map("id_nivel_acesso")
  enumAccessLevel enumAccessLevel? @relation(fields: [accessLevelId], references: [id])

  @@map("autorizacao_grupo")
}

model enumAccessLevel {
  id    String @id @default(uuid())
  value Int    @map("valor")
  name  String @map("nome")

  userAccess  userAccess[]
  groupAccess groupAccess[]

  @@map("enum_nivel_acesso")
}

model auditLog {
  id     String   @id @default(uuid())
  userId String   @map("id_usuario")
  user   user     @relation(fields: [userId], references: [id])
  date   DateTime @default(now())
  action String   @map("acao") // "SUBMIT", "REVERT"
  formId String   @map("id_formulario")
  form   form     @relation(fields: [formId], references: [id])

  changes changeLog[]

  @@map("auditlog")
}

model changeLog {
  id         Int      @id @default(autoincrement())
  auditLogId String   @map("id_auditlog")
  auditLog   auditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  table      String   @map("tabela")
  recordId   String   @map("id_registro")
  action     String   @map("tipo_acao") // "CREATE", "UPDATE", "DELETE"
  oldData    Json?    @map("dados_antigos")
  newData    Json?    @map("dados_novos")

  @@map("changelog")
}

// ===== FORMS =====
// ==x== Live Animal ==x==
model liveAnimal {
  id            Int              @id @default(autoincrement())
  specieId      Int              @map("id_especie")
  specie        specie           @relation(fields: [specieId], references: [id])
  name          String           @map("nome")
  genderId      Int              @map("id_genero")
  gender        enumAnimalGender @relation(fields: [genderId], references: [id])
  birthDate     DateTime         @map("data_nascimento")
  active        Boolean          @map("ativo")
  animalPicture String?          @map("foto_animal")
  cardLink      String?          @map("link_carteirinha")

  gpsTracking        gpsTracking?
  castration         castration?
  veterinarianVisit  veterinarianVisit[]
  vaccineApplication vaccineApplication[]
  animalInterview    animalInterview?

  @@map("animal_vivo")
}

model specie {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  liveAnimal liveAnimal[]
  deadAnimal deadAnimal[]

  @@map("especie")
}

model enumAnimalGender {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  liveAnimal liveAnimal[]

  @@map("enum_genero_animal")
}

// ==x== GPS ==x==
model gpsTracking {
  id                    Int              @id @default(autoincrement())
  liveAnimalId          Int              @unique @map("id_animal_vivo")
  liveAnimal            liveAnimal       @relation(fields: [liveAnimalId], references: [id])
  trackingDeviceId      Int              @map("id_dispositivo_rastreio")
  trackingDevice        trackingDevice   @relation(fields: [trackingDeviceId], references: [id])
  startDate             DateTime         @map("data_inicio")
  endDate               DateTime?        @map("data_fim")
  note                  String?          @map("observacao")
  monitoredDays         Int              @map("dias_monitorados")
  locationPoints        Int              @map("pontos_localizacao")
  livingArea            Float            @map("area_vida")
  monitoringMethodId    Int              @map("id_metodo_monitoramento")
  monitoringMethod      monitoringMethod @relation(fields: [monitoringMethodId], references: [id])
  rawSpreadsheetLink    String?          @map("link_planilha_bruta")
  editedSpreadsheetLink String?          @map("link_planilha_editada")

  @@map("rastreio_gps")
}

model monitoringMethod {
  id          Int    @id @default(autoincrement())
  description String @map("descricao")

  gpsTracking gpsTracking[]

  @@map("metodo_monitoramento")
}

model trackingDevice {
  id           Int     @id @default(autoincrement())
  brand        String  @map("marca")
  serialNumber String  @map("numero_serie")
  note         String? @map("observacao")

  gpsTracking gpsTracking[]

  @@map("dispositivo_rastreio")
}

// ==x== Interviews and Tutor ==x==
model animalInterview {
  id           Int        @id @default(autoincrement())
  liveAnimalId Int        @unique @map("id_animal_vivo")
  liveAnimal   liveAnimal @relation(fields: [liveAnimalId], references: [id])

  animalAnswer animalAnswer[]

  @@map("entrevista_animal")
}

model animalAnswer {
  id                   Int                 @id @default(autoincrement())
  animalInterviewId    Int                 @map("id_entrevista_animal")
  animalInterview      animalInterview     @relation(fields: [animalInterviewId], references: [id])
  animalQuestionId     Int                 @map("id_pergunta_animal")
  animalQuestion       animalQuestion      @relation(fields: [animalQuestionId], references: [id])
  text                 String?             @map("texto")
  quantity             Int?                @map("quantidade")
  animalAnswerOptionId Int?                @map("id_opcao_resposta_animal")
  animalAnswerOption   animalAnswerOption? @relation(fields: [animalAnswerOptionId], references: [id])

  @@map("resposta_animal")
}

model animalQuestion {
  id   Int    @id @default(autoincrement())
  text String @map("pergunta")

  animalAnswerOption animalAnswerOption[]
  animalAnswer       animalAnswer[]

  @@map("pergunta_animal")
}

model animalAnswerOption {
  id               Int            @id @default(autoincrement())
  animalQuestionId Int            @map("id_pergunta_animal")
  animalQuestion   animalQuestion @relation(fields: [animalQuestionId], references: [id])
  text             String         @map("resposta_possivel")

  animalAnswer animalAnswer[]

  @@map("opcao_resposta_animal")
}

model tutorInterview {
  id      Int      @id @default(autoincrement())
  tutorId Int      @unique @map("id_tutor")
  tutor   tutor    @relation(fields: [tutorId], references: [id])
  date    DateTime @map("data")

  tutorAnswer tutorAnswer[]

  @@map("entrevista_tutor")
}

model tutor {
  id        Int        @id @default(autoincrement())
  name      String     @map("nome")
  genderId  Int        @map("id_genero")
  gender    enumGender @relation(fields: [genderId], references: [id])
  birthDate DateTime   @map("data_nascimento")

  tutorInterview tutorInterview?
  necropsy       necropsy[]

  @@map("tutor")
}

model enumGender {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  tutor tutor[]

  @@map("enum_genero")
}

model tutorAnswer {
  id                  Int                @id @default(autoincrement())
  tutorInterviewId    Int                @map("id_entrevista_tutor")
  tutorInterview      tutorInterview     @relation(fields: [tutorInterviewId], references: [id])
  tutorQuestionId     Int                @map("id_pergunta_tutor")
  tutorQuestion       tutorQuestion      @relation(fields: [tutorQuestionId], references: [id])
  text                String?            @map("texto")
  quantity            Int?               @map("quantidade")
  tutorAnswerOptionId Int?               @map("id_opcao_resposta_tutor")
  tutorAnswerOption   tutorAnswerOption? @relation(fields: [tutorAnswerOptionId], references: [id])

  @@map("resposta_tutor")
}

model tutorAnswerOption {
  id              Int           @id @default(autoincrement())
  tutorQuestionId Int           @map("id_pergunta_tutor")
  tutorQuestion   tutorQuestion @relation(fields: [tutorQuestionId], references: [id])
  text            String        @map("resposta_possivel")

  tutorAnswer tutorAnswer[]

  @@map("opcao_resposta_tutor")
}

model tutorQuestion {
  id   Int    @id @default(autoincrement())
  text String @map("pergunta")

  tutorAnswerOption tutorAnswerOption[]
  tutorAnswer       tutorAnswer[]

  @@map("pergunta_tutor")
}

// Health

model castration {
  id                  Int               @id @default(autoincrement())
  liveAnimalId        Int               @unique @map("id_animal_vivo")
  liveAnimal          liveAnimal        @relation(fields: [liveAnimalId], references: [id])
  veterinarianVisitId Int               @unique @map("id_visita_veterinaria")
  veterinarianVisit   veterinarianVisit @relation(fields: [veterinarianVisitId], references: [id])
  date                DateTime          @map("data")
  note                String?           @map("observacao")

  @@map("castracao")
}

model veterinarianVisit {
  id             Int          @id @default(autoincrement())
  liveAnimalId   Int          @map("id_animal_vivo")
  liveAnimal     liveAnimal   @relation(fields: [liveAnimalId], references: [id])
  veterinarianId Int          @map("id_veterinario")
  veterinarian   veterinarian @relation(fields: [veterinarianId], references: [id])
  date           DateTime     @map("data")
  animalPicture  String?      @map("foto_animal")
  note           String?      @map("observacao")

  castration           castration?
  vaccineApplication   vaccineApplication[]
  exam                 exam?
  stoolAnalysis        stoolAnalysis?
  physicalExam         physicalExam?
  bodyMeasurement      bodyMeasurementVeterinarian[]
  ectoparasiteAnalysis ectoparasiteAnalysisVeterinarian[]
  sorologyAnalysis     sorologyAnalysis?
  sampleAllocation     sampleAllocationVeterinarian[]
  examResult           examResult?

  @@unique([liveAnimalId, veterinarianId, date])
  @@map("visita_veterinaria")
}

model veterinarian {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  veterinarianVisit veterinarianVisit[]

  @@map("veterinario")
}

model vaccine {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  vaccineApplication vaccineApplication[]

  @@map("vacina")
}

model vaccineApplication {
  id                  Int                @id @default(autoincrement())
  liveAnimalId        Int                @map("id_animal_vivo")
  liveAnimal          liveAnimal         @relation(fields: [liveAnimalId], references: [id])
  vaccineId           Int                @map("id_vacina")
  vaccine             vaccine            @relation(fields: [vaccineId], references: [id])
  veterinarianVisitId Int?               @map("id_visita_veterinaria")
  veterinarianVisit   veterinarianVisit? @relation(fields: [veterinarianVisitId], references: [id])
  date                DateTime           @map("data")
  vaccineTypeId       Int                @map("id_tipo_vacina")
  vaccineType         enumVaccineType    @relation(fields: [vaccineTypeId], references: [id])

  @@map("aplicacao_vacina")
}

model enumVaccineType {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  vaccineApplication vaccineApplication[]

  @@map("enum_tipo_vacina")
}

model exam {
  id                  Int                      @id @default(autoincrement())
  veterinarianVisitId Int                      @unique @map("id_visita_veterinaria")
  veterinarianVisit   veterinarianVisit        @relation(fields: [veterinarianVisitId], references: [id])
  generalConditionId  Int                      @map("id_estado_geral")
  generalCondition    enumExamGeneralCondition @relation(fields: [generalConditionId], references: [id])
  interpretationId    Int                      @map("id_interpretacao")
  interpretation      enumExamInterpretation   @relation(fields: [interpretationId], references: [id])
  note                String?                  @map("observacao")

  examValue examValue[]

  @@map("exame")
}

model enumExamGeneralCondition {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  exam exam[]

  @@map("enum_estado_geral")
}

model enumExamInterpretation {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  exam exam[]

  @@map("enum_interpretacao")
}

model examValue {
  id               Int                          @id @default(autoincrement())
  examId           Int                          @map("id_exame")
  exam             exam                         @relation(fields: [examId], references: [id])
  examTypeId       Int                          @map("id_tipo_exame")
  examType         examType                     @relation(fields: [examTypeId], references: [id])
  value            String                       @map("valor")
  interpretationId Int?                         @map("id_interpretacao")
  interpretation   enumExamValueInterpretation? @relation(fields: [interpretationId], references: [id])

  @@map("valor_exame")
}

model enumExamValueInterpretation {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  examValue examValue[]

  @@map("enum_interpretacao_valor_exame")
}

model examType {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  examValue examValue[]

  @@map("tipo_exame")
}

model stoolAnalysis {
  id                     Int                  @id @default(autoincrement())
  veterinarianVisitId    Int                  @unique @map("id_visita_veterinaria")
  veterinarianVisit      veterinarianVisit    @relation(fields: [veterinarianVisitId], references: [id])
  weight                 Float                @map("peso")
  processingTechnologyId Int                  @map("id_tecnologia_processamento")
  processingTechnology   processingTechnology @relation(fields: [processingTechnologyId], references: [id])
  note                   String?              @map("observacao")

  eggCystAnalysis   eggCystAnalysis[]
  molecularAnalysis molecularAnalysis[]

  @@map("analise_fezes")
}

model processingTechnology {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  stoolAnalysis stoolAnalysis[]

  @@map("tecnologia_processamento")
}

model eggCystAnalysis {
  id              Int           @id @default(autoincrement())
  stoolAnalysisId Int           @map("id_analise_fezes")
  stoolAnalysis   stoolAnalysis @relation(fields: [stoolAnalysisId], references: [id])
  eggCystSpecieId Int           @map("id_especie_ovo_cisto")
  eggCystSpecie   eggCystSpecie @relation(fields: [eggCystSpecieId], references: [id])
  quantity        Int           @map("quantidade")
  note            String?       @map("observacao")

  @@map("analise_ovo_cisto")
}

model eggCystSpecie {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  eggCystAnalysis   eggCystAnalysis[]
  molecularAnalysis molecularAnalysis[]

  @@map("especie_ovo_cisto")
}

model molecularAnalysis {
  id              Int           @id @default(autoincrement())
  stoolAnalysisId Int           @map("id_analise_fezes")
  stoolAnalysis   stoolAnalysis @relation(fields: [stoolAnalysisId], references: [id])
  eggCystSpecieId Int           @map("id_especie_ovo_cisto")
  eggCystSpecie   eggCystSpecie @relation(fields: [eggCystSpecieId], references: [id])
  note            String?       @map("observacao")

  @@map("analise_molecular")
}

model physicalExam {
  id                  Int                              @id @default(autoincrement())
  veterinarianVisitId Int                              @unique @map("id_visita_veterinaria")
  veterinarianVisit   veterinarianVisit                @relation(fields: [veterinarianVisitId], references: [id])
  generalConditionId  Int                              @map("id_estado_geral")
  generalCondition    enumPhysicalExamGeneralCondition @relation(fields: [generalConditionId], references: [id])
  fr                  String                           @map("FR")
  fc                  Int                              @map("FC")
  tempRectal          Float                            @map("temp_retal")
  mucousId            Int                              @map("id_mucosa")
  mucous              enumMucous                       @relation(fields: [mucousId], references: [id])
  tpc                 Int                              @map("TPC")
  hydrationId         Int                              @map("id_hidratacao")
  hydration           enumHydration                    @relation(fields: [hydrationId], references: [id])
  weight              Float                            @map("peso")
  score               Int                              @map("score")
  bloodCollectionNote String?                          @map("observacao_coleta_sangue")
  physicalExamNote    String?                          @map("observacao_exame_fisico")
  generalNote         String?                          @map("observacao_geral")

  @@map("exame_fisico")
}

model enumPhysicalExamGeneralCondition {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  physicalExam physicalExam[]

  @@map("enum_estado_geral_exame_fisico")
}

model enumMucous {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  physicalExam physicalExam[]

  @@map("enum_mucosa")
}

model enumHydration {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  physicalExam physicalExam[]

  @@map("enum_hidratacao")
}

model bodyMeasurementVeterinarian {
  id                    Int                             @id @default(autoincrement())
  veterinarianVisitId   Int                             @map("id_visita_veterinaria")
  veterinarianVisit     veterinarianVisit               @relation(fields: [veterinarianVisitId], references: [id])
  bodyMeasurementTypeId Int                             @map("id_tipo_medida_corporal")
  bodyMeasurementType   bodyMeasurementTypeVeterinarian @relation(fields: [bodyMeasurementTypeId], references: [id])
  value                 Float                           @map("valor")

  @@unique([veterinarianVisitId, bodyMeasurementTypeId])
  @@map("medida_corporal_veterinario")
}

model bodyMeasurementTypeVeterinarian {
  id          Int    @id @default(autoincrement())
  description String @map("descricao")
  unit        String @map("unidade")

  bodyMeasurementVeterinarian bodyMeasurementVeterinarian[]

  @@map("tipo_medida_corporal_veterinario")
}

model bodyMeasurementTypeNecropsy {
  id          Int    @id @default(autoincrement())
  description String @map("descricao")
  unit        String @map("unidade")

  bodyMeasurementNecropsy bodyMeasurementNecropsy[]

  @@map("tipo_medida_corporal_necropsia")
}

model ectoparasiteAnalysisVeterinarian {
  id                      Int                @id @default(autoincrement())
  veterinarianVisitId     Int                @map("id_visita_veterinaria")
  veterinarianVisit       veterinarianVisit  @relation(fields: [veterinarianVisitId], references: [id])
  ectoparasiteGenusId     Int                @map("id_genero_ectoparasito")
  ectoparasiteGenus       ectoparasiteGenus  @relation(fields: [ectoparasiteGenusId], references: [id])
  ectoparasiteSpecieId    Int                @map("id_especie_ectoparasito")
  ectoparasiteSpecie      ectoparasiteSpecie @relation("specie", fields: [ectoparasiteSpecieId], references: [id])
  ectoparasiteSubSpecieId Int                @map("id_subespecie_ectoparasito")
  ectoparasiteSubSpecie   ectoparasiteSpecie @relation("subspecie", fields: [ectoparasiteSubSpecieId], references: [id])
  maleQuantity            Int                @map("quantidade_machos")
  femaleQuantity          Int                @map("quantidade_femeas")
  nymphQuantity           Int                @map("quantidade_ninfas")
  larvaeQuantity          Int                @map("quantidade_larvas")
  eggQuantity             Int                @map("quantidade_ovos")
  note                    String?            @map("observacao")

  @@unique([veterinarianVisitId, ectoparasiteGenusId, ectoparasiteSpecieId, ectoparasiteSubSpecieId])
  @@map("analise_ectoparasito_veterinario")
}

model ectoparasiteGenus {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  ectoparasiteAnalysisVeterinarian ectoparasiteAnalysisVeterinarian[]
  ectoparasiteAnalysisNecropsy     ectoparasiteAnalysisNecropsy[]

  @@map("genero_ectoparasito")
}

model ectoparasiteSpecie {
  id   Int    @id @default(autoincrement())
  name String @map("nome")

  ectoparasiteAnalysisVeterinarianSpecie    ectoparasiteAnalysisVeterinarian[] @relation("specie")
  ectoparasiteAnalysisVeterinarianSubSpecie ectoparasiteAnalysisVeterinarian[] @relation("subspecie")
  ectoparasiteAnalysisNecropsySpecie        ectoparasiteAnalysisNecropsy[]     @relation("specie")
  ectoparasiteAnalysisNecropsySubSpecie     ectoparasiteAnalysisNecropsy[]     @relation("subspecie")

  @@map("especie_ectoparasito")
}

model examResult {
  id                       Int               @id @default(autoincrement())
  veterinarianVisitId      Int               @unique @map("id_visita_veterinaria")
  veterinarianVisit        veterinarianVisit @relation(fields: [veterinarianVisitId], references: [id])
  erythrocytes             Float             @map("eritrocitos")
  hemoglobin               Float             @map("hemoglobina")
  hematocrit               Float             @map("hematocrito")
  vcm                      Float             @map("vcm")
  hcm                      Float             @map("hcm")
  chcm                     Float             @map("chcm")
  platelets                Float             @map("plaquetas")
  whiteBloodCells          Float             @map("leucocitos")
  bandCells                Float             @map("bastonetes")
  segmentedCells           Float             @map("segmentados")
  segmentedCellsPercentage Float             @map("segmentados_percentual")
  lymphocytes              Float             @map("linfocitos")
  lymphocytesPercentage    Float             @map("linfocitos_percentual")
  monocytes                Float             @map("monocitos")
  monocytesPercentage      Float             @map("monocitos_percentual")
  eosinophils              Float             @map("eosinofilos")
  eosinophilsPercentage    Float             @map("eosinofilos_percentual")
  basophils                Float             @map("basofilos")
  basophilsPercentage      Float             @map("basofilos_percentual")
  alt                      Float             @map("alt")
  creatinine               Float             @map("creatinina")
  alkalinePhosphatase      Float             @map("fosfatase_alcalina")
  totalProtein             Float             @map("proteina_total")
  urea                     Float             @map("ureia")

  @@map("resultado_exame")
}

model sorologyAnalysis {
  id                  Int                        @id @default(autoincrement())
  veterinarianVisitId Int                        @unique @map("id_visita_veterinaria")
  veterinarianVisit   veterinarianVisit          @relation(fields: [veterinarianVisitId], references: [id])
  sorologyTestId      Int                        @map("id_teste_sorologico")
  sorologyTest        sorologyTest               @relation(fields: [sorologyTestId], references: [id])
  sorologyAgentId     Int                        @map("id_agente_sorologico")
  sorologyAgent       sorologyAgent              @relation(fields: [sorologyAgentId], references: [id])
  cuttingPointSymbol  String                     @map("simbolo_ponto_corte")
  cuttingPointValue   String                     @map("valor_ponto_corte")
  resultTypeId        Int                        @map("id_tipo_resultado")
  resultType          enumSorologyResultType     @relation(fields: [resultTypeId], references: [id])
